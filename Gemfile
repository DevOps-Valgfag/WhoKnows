source 'https://rubygems.org'

# Core web framework
gem 'sinatra'
gem 'sinatra-contrib' # Provides useful features like reloading

# Database and ORM
gem 'sqlite3'
gem 'activerecord', '~> 7.0'
gem 'sinatra-activerecord'
gem 'rake'

# Secure password handling
gem 'bcrypt'

# Flash messages (for notifications like "Successfully logged in")
gem 'sinatra-flash'

# For running the server
gem 'puma'

# Testing framework
group :test do
  gem 'rspec'
  gem 'rack-test'
  gem 'capybara'
end
gem "rackup", "~> 2.2"
