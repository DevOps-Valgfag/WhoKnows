<h2>Sign Up</h2>
<% if @error %>
  <div class="error"><strong>Error:</strong> <%= @error.full_messages.join(', ') %></div>
<% end %>
<form action="/register" method="POST">
  <dl>
    <dt>Username:</dt>
    <dd><input type="text" name="username" size="30" value="<%= @user.username %>"></dd>
    <dt>E-Mail:</dt>
    <dd><input type="text" name="email" size="30" value="<%= @user.email %>"></dd>
    <dt>Password:</dt>
    <dd><input type="password" name="password" size="30"></dd>
    <dt>Password <small>(repeat)</small>:</dt>
    <dd><input type="password" name="password_confirmation" size="30"></dd>
  </dl>
  <div class="actions"><input type="submit" value="Sign Up"></div>
</form>